<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <!--
        stdoutLogEnabled="true" captures all .NET startup exceptions to .\logs\stdout_*.log
        on Azure App Service. This is intentional: without it, any crash before the first
        request produces only the generic HTTP 500.30 / 0x8007023e with no inner detail.
        Azure creates the logs\ directory automatically when logging is enabled.
      -->
      <aspNetCore processPath="dotnet" arguments=".\STBWeb.dll"
                  stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" startupTimeLimit="120" />
    </system.webServer>
  </location>
</configuration>
