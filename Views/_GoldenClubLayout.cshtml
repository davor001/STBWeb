@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    var pageTitle = Model?.Value<string>("seoTitle") ?? Model?.Name ?? "Golden Club";
}
<!DOCTYPE html>
<html lang="mk">
<head>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VNYDDYL1MY"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-VNYDDYL1MY');</script>

    <meta charset="utf-8" />
    <title>@pageTitle - Golden Club</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="icon" href="/images/favicon.png" type="image/png" />
    <link href="/css/GoldenClub.css?v=0.1.5" rel="stylesheet" type="text/css" />
    <link href="/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
</head>
<body data-layout="topnav">
    <div class="wrapper">
        <div class="content-page">
            <div class="content" id="master_page_content">

                <!-- Golden Club Navbar -->
                <div class="topnav" id="navbar">
                    <div class="container-fluid">
                        <nav class="navbar navbar-light navbar-expand-lg topnav-menu w-100">
                            <a class="navbar-brand" href="/goldenclub">
                                <span class="topnav-logo-lg">
                                    <img src="/media/logogoldenclub-e1475663697742.png" alt="Golden Club" class="img-fluid" style="max-height:50px;">
                                </span>
                            </a>
                            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#gcNavbar"
                                    aria-expanded="false" aria-label="Toggle navigation">
                                <span class="navbar-toggler-icon"></span>
                            </button>
                            <div class="collapse navbar-collapse" id="gcNavbar">
                                <ul class="navbar-nav w-100">
                                    <li><a class="nav-link" href="/goldenclub/">Почетна</a></li>
                                </ul>
                            </div>
                        </nav>
                    </div>
                </div>

                @RenderBody()

                <!-- Golden Club Footer -->
                <footer class="footer">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-sm-12 col-md-6 text-center">
                                <img src="/media/2279/stb_logo_bottom_mk.png" class="img-fluid d-inline-block" alt="STB">
                            </div>
                            <div class="col-sm-12 col-md-6 text-center mt-2">
                                <ul class="list-unstyled footer-social d-inline-block">
                                    <li><a href="https://www.facebook.com/stopanskabankaSK/" target="_blank" class="nav-link" aria-label="Facebook"><i class="mdi mdi-facebook"></i></a></li>
                                    <li><a href="https://www.linkedin.com/company/stopanska-banka-ad-skopje/" target="_blank" class="nav-link" aria-label="LinkedIn"><i class="mdi mdi-linkedin"></i></a></li>
                                    <li><a href="https://www.instagram.com/stopanskabanka/" target="_blank" class="nav-link" aria-label="Instagram"><i class="mdi mdi-instagram"></i></a></li>
                                    <li><a href="https://www.youtube.com/user/stopanskabankamk" target="_blank" class="nav-link" aria-label="YouTube"><i class="mdi mdi-youtube"></i></a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </footer>

            </div>
        </div>
    </div>

    <script src="https://ajax.aspnetcdn.com/ajax/jQuery/jquery-3.0.0.min.js"></script>
    <script src="/assets/js/app.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>