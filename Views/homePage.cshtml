@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Cms.Core.Strings
@inject STBWeb.Services.HomepageFallbackService HomepageFallbackService
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "~/Views/_Layout.cshtml";

    string ResolveFallbackMediaUrl(string? localPath, string? remoteUrl = null)
    {
        if (!string.IsNullOrWhiteSpace(localPath))
        {
            return "/" + localPath.Replace("\\", "/").TrimStart('/');
        }

        return remoteUrl ?? string.Empty;
    }

    string NormalizeFallbackUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return string.Empty;
        }

        var trimmed = url.Trim();
        if (trimmed.StartsWith("#", StringComparison.Ordinal))
        {
            return trimmed;
        }

        if (trimmed.StartsWith("javascript:", StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        if (trimmed.StartsWith("//", StringComparison.Ordinal))
        {
            if (Uri.TryCreate($"https:{trimmed}", UriKind.Absolute, out var protocolRelativeUri))
            {
                return protocolRelativeUri.Host.Equals("stb.com.mk", StringComparison.OrdinalIgnoreCase) ||
                       protocolRelativeUri.Host.Equals("www.stb.com.mk", StringComparison.OrdinalIgnoreCase)
                    ? $"{(string.IsNullOrWhiteSpace(protocolRelativeUri.AbsolutePath) ? "/" : protocolRelativeUri.AbsolutePath)}{protocolRelativeUri.Query}{protocolRelativeUri.Fragment}"
                    : trimmed;
            }

            return string.Empty;
        }

        if (Uri.TryCreate(trimmed, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.Host.Equals("stb.com.mk", StringComparison.OrdinalIgnoreCase) ||
                   absoluteUri.Host.Equals("www.stb.com.mk", StringComparison.OrdinalIgnoreCase)
                ? $"{(string.IsNullOrWhiteSpace(absoluteUri.AbsolutePath) ? "/" : absoluteUri.AbsolutePath)}{absoluteUri.Query}{absoluteUri.Fragment}"
                : trimmed;
        }

        if (!Uri.TryCreate(trimmed, UriKind.Relative, out _))
        {
            return string.Empty;
        }

        if (trimmed.StartsWith("?", StringComparison.Ordinal))
        {
            return trimmed;
        }

        while (trimmed.StartsWith("./", StringComparison.Ordinal))
        {
            trimmed = trimmed[2..];
        }

        while (trimmed.StartsWith("../", StringComparison.Ordinal))
        {
            trimmed = trimmed[3..];
        }

        return "/" + trimmed.TrimStart('/');
    }

    string GetPublishedMediaUrl(MediaWithCrops? media) => media?.MediaUrl() ?? string.Empty;

    string GetNewsExcerpt(IPublishedContent newsItem)
    {
        var summary = newsItem.Value<string>("summary");
        if (!string.IsNullOrWhiteSpace(summary))
        {
            return summary.Trim();
        }

        var articleBody = newsItem.Value<IHtmlEncodedString>("articleBody")?.ToString();
        if (string.IsNullOrWhiteSpace(articleBody))
        {
            return string.Empty;
        }

        return articleBody.StripHtml().Truncate(160);
    }

    MediaWithCrops? GetPromoImage(IPublishedContent? promoNode)
    {
        if (promoNode == null)
        {
            return null;
        }

        var mediaAliases = new[]
        {
            "promoImage",
            "logo",
            "thumbnailImage",
            "heroBannerImage",
            "bannerImage",
            "productBannerImage",
            "applyOnlineImage",
            "desktopImage"
        };

        foreach (var alias in mediaAliases)
        {
            var media = promoNode.Value<MediaWithCrops>(alias);
            if (media != null)
            {
                return media;
            }
        }

        var firstHeroSlide = promoNode.Value<BlockListModel>("heroSlides")?.FirstOrDefault()?.Content;
        return firstHeroSlide?.Value<MediaWithCrops>("desktopImage")
            ?? firstHeroSlide?.Value<MediaWithCrops>("mobileImage");
    }

    // Temporary homepage verification fallback. Prefer Umbraco data and only fill missing homepage sections from scraped-data/homepage.json.
    var homepageFallback = HomepageFallbackService.GetData();

    var umbracoHeroSlides = Model.Value<BlockListModel>("heroSlides")?
        .Select(x => x.Content)
        .OfType<IPublishedContent>()
        .ToList() ?? new List<IPublishedContent>();
    var heroSlides = umbracoHeroSlides.Any()
        ? umbracoHeroSlides.Select(slide => (
            Heading: slide.Value<string>("slideHeading") ?? string.Empty,
            Subheading: slide.Value<string>("slideSubheading") ?? string.Empty,
            CtaText: slide.Value<string>("slideCtaText") ?? string.Empty,
            CtaUrl: slide.Value<IEnumerable<Link>>("slideCtaUrl")?.FirstOrDefault()?.Url ?? string.Empty,
            DesktopImageUrl: GetPublishedMediaUrl(slide.Value<MediaWithCrops>("desktopImage")),
            MobileImageUrl: GetPublishedMediaUrl(slide.Value<MediaWithCrops>("mobileImage"))
        )).ToList()
        : homepageFallback.HeroSlides.Select(slide => (
            Heading: slide.SlideHeading,
            Subheading: slide.SlideSubheading,
            CtaText: slide.SlideCtaText,
            CtaUrl: NormalizeFallbackUrl(slide.SlideCtaUrl),
            DesktopImageUrl: ResolveFallbackMediaUrl(slide.DesktopImageLocalPath, slide.DesktopImageUrl),
            MobileImageUrl: ResolveFallbackMediaUrl(slide.MobileImageLocalPath, slide.MobileImageUrl)
        )).ToList();

    var umbracoFeatureIcons = Model.Value<BlockListModel>("featureIconLinks")?
        .Select(x => x.Content)
        .OfType<IPublishedContent>()
        .ToList() ?? new List<IPublishedContent>();
    var featureIcons = umbracoFeatureIcons.Any()
        ? umbracoFeatureIcons.Select(icon => (
            Label: icon.Value<string>("label") ?? string.Empty,
            LinkUrl: icon.Value<IEnumerable<Link>>("linkUrl")?.FirstOrDefault()?.Url ?? "#",
            IconMdiClass: icon.Value<string>("iconMdiClass") ?? "mdi-help-circle",
            IconColor: icon.Value<string>("iconColor") ?? "#0056a6"
        )).ToList()
        : homepageFallback.FeatureIconLinks.Select(icon => (
            Label: icon.Label,
            LinkUrl: NormalizeFallbackUrl(icon.LinkUrl),
            IconMdiClass: string.IsNullOrWhiteSpace(icon.IconMdiClass) ? "mdi-help-circle" : icon.IconMdiClass,
            IconColor: string.IsNullOrWhiteSpace(icon.IconColor) ? "#0056a6" : icon.IconColor
        ))
        .Select(icon => (
            Label: icon.Label,
            LinkUrl: string.IsNullOrWhiteSpace(icon.LinkUrl) ? "#" : icon.LinkUrl,
            IconMdiClass: icon.IconMdiClass,
            IconColor: icon.IconColor
        ))
        .ToList();

    var applyImageUrl = GetPublishedMediaUrl(Model.Value<MediaWithCrops>("applyOnlineImage"));
    if (string.IsNullOrWhiteSpace(applyImageUrl))
    {
        applyImageUrl = ResolveFallbackMediaUrl(homepageFallback.ApplyOnline.ImageLocalPath, homepageFallback.ApplyOnline.ImageUrl);
    }

    var applyUrl = Model.Value<IEnumerable<Link>>("applyOnlineUrl")?.FirstOrDefault()?.Url;
    if (string.IsNullOrWhiteSpace(applyUrl))
    {
        applyUrl = NormalizeFallbackUrl(homepageFallback.ApplyOnline.TargetUrl);
    }

    if (string.IsNullOrWhiteSpace(applyUrl))
    {
        applyUrl = "/appForm/";
    }

    var promoBanners = new[]
        {
            Model.Value<IPublishedContent>("promoBanner1"),
            Model.Value<IPublishedContent>("promoBanner2")
        }
        .OfType<IPublishedContent>()
        .Select(promoNode => (
            Name: promoNode.Name,
            Url: promoNode.Url() ?? string.Empty,
            ImageUrl: GetPublishedMediaUrl(GetPromoImage(promoNode))
        ))
        .Where(promo =>
            !string.IsNullOrWhiteSpace(promo.Name) ||
            !string.IsNullOrWhiteSpace(promo.Url) ||
            !string.IsNullOrWhiteSpace(promo.ImageUrl))
        .ToList();

    if (promoBanners.Count < 2)
    {
        var existingPromoUrls = new HashSet<string>(promoBanners.Select(x => x.Url), StringComparer.OrdinalIgnoreCase);

        foreach (var promo in homepageFallback.PromoBanners)
        {
            if (promoBanners.Count >= 2)
            {
                break;
            }

            var normalizedPromoUrl = NormalizeFallbackUrl(promo.TargetUrl);
            if (!string.IsNullOrWhiteSpace(normalizedPromoUrl) && existingPromoUrls.Contains(normalizedPromoUrl))
            {
                continue;
            }

            var imageUrl = ResolveFallbackMediaUrl(promo.ImageLocalPath, promo.ImageUrl);
            if (string.IsNullOrWhiteSpace(promo.Name) &&
                string.IsNullOrWhiteSpace(normalizedPromoUrl) &&
                string.IsNullOrWhiteSpace(imageUrl))
            {
                continue;
            }

            promoBanners.Add((promo.Name, normalizedPromoUrl, imageUrl));

            if (!string.IsNullOrWhiteSpace(normalizedPromoUrl))
            {
                existingPromoUrls.Add(normalizedPromoUrl);
            }
        }
    }

    var newsRoot = Umbraco.ContentAtRoot()
        .SelectMany(r => r.DescendantsOrSelf())
        .FirstOrDefault(c => c.ContentType.Alias == "newsListingPage");
    var latestNews = new List<(string Title, string Url, string PublishDate, string Excerpt, string ThumbnailUrl)>();

    if (newsRoot != null)
    {
        foreach (var news in newsRoot.Children()
            .Where(c => c.ContentType.Alias == "newsDetailPage")
            .OrderByDescending(c => c.Value<DateTime>("publishDate"))
            .Take(5))
        {
            var publishDate = news.HasValue("publishDate")
                ? news.Value<DateTime>("publishDate").ToString("dd.MM.yyyy")
                : string.Empty;

            latestNews.Add((
                Title: news.Name,
                Url: news.Url() ?? string.Empty,
                PublishDate: publishDate,
                Excerpt: GetNewsExcerpt(news),
                ThumbnailUrl: GetPublishedMediaUrl(news.Value<MediaWithCrops>("thumbnailImage"))
            ));
        }
    }

    if (latestNews.Count < 5)
    {
        var existingNewsUrls = new HashSet<string>(latestNews.Select(x => x.Url), StringComparer.OrdinalIgnoreCase);

        foreach (var news in homepageFallback.LatestNews)
        {
            if (latestNews.Count >= 5)
            {
                break;
            }

            var normalizedNewsUrl = NormalizeFallbackUrl(news.Url);
            if (string.IsNullOrWhiteSpace(normalizedNewsUrl) || existingNewsUrls.Contains(normalizedNewsUrl))
            {
                continue;
            }

            latestNews.Add((
                Title: news.Title,
                Url: normalizedNewsUrl,
                PublishDate: news.PublishDate,
                Excerpt: news.Excerpt,
                ThumbnailUrl: ResolveFallbackMediaUrl(news.ThumbnailLocalPath, news.ThumbnailUrl)
            ));

            existingNewsUrls.Add(normalizedNewsUrl);
        }
    }

    var allNewsUrl = newsRoot?.Url();
    if (string.IsNullOrWhiteSpace(allNewsUrl))
    {
        allNewsUrl = "/novosti/";
    }

    // ── Section text labels (editable in backoffice, hardcoded fallbacks) ─
    var whatINeedTitle = Model.Value<string>("whatINeedTitle");
    if (string.IsNullOrWhiteSpace(whatINeedTitle)) whatINeedTitle = "ШТО МИ ТРЕБА?";

    var applyOnlineTitle = Model.Value<string>("applyOnlineTitle");
    if (string.IsNullOrWhiteSpace(applyOnlineTitle)) applyOnlineTitle = "Аплицирај онлајн";

    var applyOnlineButtonText = Model.Value<string>("applyOnlineButtonText");
    if (string.IsNullOrWhiteSpace(applyOnlineButtonText)) applyOnlineButtonText = "Аплицирај сега";

    var exchangeRateTitle = Model.Value<string>("exchangeRateTitle");
    if (string.IsNullOrWhiteSpace(exchangeRateTitle)) exchangeRateTitle = "КУРСНА ЛИСТА";

    var exchangeRateAllLabel = Model.Value<string>("exchangeRateAllLabel");
    if (string.IsNullOrWhiteSpace(exchangeRateAllLabel)) exchangeRateAllLabel = "Целосна листа";

    var exchangeRateAllUrl = Model.Value<IEnumerable<Link>>("exchangeRateAllUrl")?.FirstOrDefault()?.Url;
    if (string.IsNullOrWhiteSpace(exchangeRateAllUrl)) exchangeRateAllUrl = "/finansiski-pazari/kursna-lista/";

    var latestNewsTitle = Model.Value<string>("latestNewsTitle");
    if (string.IsNullOrWhiteSpace(latestNewsTitle)) latestNewsTitle = "СООПШТЕНИЈА";

    var latestNewsAllLabel = Model.Value<string>("latestNewsAllLabel");
    if (string.IsNullOrWhiteSpace(latestNewsAllLabel)) latestNewsAllLabel = "Сите соопштенија";

    var newsReadMoreLabel = Model.Value<string>("newsReadMoreLabel");
    if (string.IsNullOrWhiteSpace(newsReadMoreLabel)) newsReadMoreLabel = "повеќе";

    var digitalChannelsTitle = Model.Value<string>("digitalChannelsTitle");
    if (string.IsNullOrWhiteSpace(digitalChannelsTitle)) digitalChannelsTitle = "ДИГИТАЛНИ КАНАЛИ 24/7";

    // ── Digital Channels (BlockList with fallback to hardcoded defaults) ─
    var umbracoDigitalChannels = Model.Value<BlockListModel>("digitalChannels")?
        .Select(x => x.Content)
        .OfType<IPublishedContent>()
        .ToList() ?? new List<IPublishedContent>();

    var digitalChannels = umbracoDigitalChannels.Any()
        ? umbracoDigitalChannels.Select(ch => (
            Title: ch.Value<string>("channelTitle") ?? string.Empty,
            Icon: ch.Value<string>("channelIcon") ?? "mdi-bank",
            Description: ch.Value<string>("channelDescription") ?? string.Empty,
            Url: ch.Value<IEnumerable<Link>>("channelUrl")?.FirstOrDefault()?.Url ?? "#"
        )).ToList()
        : new List<(string Title, string Icon, string Description, string Url)>
        {
            ("e-banking",               "mdi-laptop-chromebook", "Достапен 24/7 за безбедно, брзо и лесно управување со вашите финансии",                                             "/naselenie/digitalno-bankarstvo/e-banking/"),
            ("m-banking",               "mdi-cellphone-iphone",  "БЕСПЛАТНА Android и iOS апликација за 24/7 банка во вашиот мобилен",                                                 "/naselenie/digitalno-bankarstvo/m-banking/"),
            ("Брзи плаќања - Topsi Pay","mdi-coin",              "сервис за БРЗИ плаќања кон пријателите на Facebook или контактите во мобилниот телефон",                             "/naselenie/digitalno-bankarstvo/brzi-plakjanja-topsi-pay/"),
            ("E-Commerce",              "mdi-cart-outline",      "Сервис за е-commerce на Стопанска Банка е наменет за правни лица кои имаат сметка во Банката или планираат да отворат","/pravni-lica/digitalno-bankarstvo/e-commerce/"),
        };
}

<!-- Hero Carousel -->
@if (heroSlides.Any())
{
    <div id="homeMainSlider" class="carousel slide" data-ride="carousel">
        <ol class="carousel-indicators">
            @{
                var idx = 0;
            }
            @foreach (var _ in heroSlides)
            {
                <li data-target="#homeMainSlider" data-slide-to="@idx" class="@(idx == 0 ? "active" : "")"></li>
                idx++;
            }
        </ol>
        <div class="carousel-inner">
            @{
                idx = 0;
            }
            @foreach (var slide in heroSlides)
            {
                var slideImageUrl = !string.IsNullOrWhiteSpace(slide.DesktopImageUrl)
                    ? slide.DesktopImageUrl
                    : slide.MobileImageUrl;

                <div class="carousel-item @(idx == 0 ? "active" : "")">
                    @if (!string.IsNullOrWhiteSpace(slideImageUrl))
                    {
                        <picture>
                            @if (!string.IsNullOrWhiteSpace(slide.MobileImageUrl))
                            {
                                <source media="(max-width: 767.98px)" srcset="@slide.MobileImageUrl">
                            }
                            <img src="@slideImageUrl" class="d-block w-100" alt="@(string.IsNullOrWhiteSpace(slide.Heading) ? Model.Name : slide.Heading)">
                        </picture>
                    }
                    @if (!string.IsNullOrEmpty(slide.Heading))
                    {
                        <div class="carousel-caption carousel-caption-left2">
                            <h3>@slide.Heading</h3>
                            <hr />
                            @if (!string.IsNullOrEmpty(slide.Subheading))
                            {
                                <h4>@slide.Subheading</h4>
                            }
                            @if (!string.IsNullOrEmpty(slide.CtaText) && !string.IsNullOrEmpty(slide.CtaUrl))
                            {
                                <a href="@slide.CtaUrl" class="btn btn-primary">@slide.CtaText</a>
                            }
                        </div>
                    }
                </div>
                idx++;
            }
        </div>
        <a class="carousel-control-prev" href="#homeMainSlider" role="button" data-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </a>
        <a class="carousel-control-next" href="#homeMainSlider" role="button" data-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </a>
    </div>
}

<!-- News Ticker -->
@await Html.PartialAsync("_NewsTicker")

<!-- "Што ми треба?" Icon Grid -->
@if (featureIcons.Any())
{
    <div class="home-what-i-need">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 text-center">
                    <h3 class="home-what-i-need-title mb-2 mt-1">@whatINeedTitle</h3>
                </div>
                <div class="col-12">
                    <div class="win-icon-row">
                        @foreach (var icon in featureIcons)
                        {
                            <div class="win-icon-col">
                                <a href="@icon.LinkUrl" class="win-icon">
                                    <span class="win-icon-circle" style="background-color:@icon.IconColor;">
                                        <i class="mdi @icon.IconMdiClass"></i>
                                    </span>
                                    <span class="icon-text">@icon.Label</span>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- 3-column Home Block -->
<div class="container-fluid py-4">
    <div class="row home-block-main">

        <!-- Apply Online Card -->
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                @if (!string.IsNullOrWhiteSpace(applyImageUrl))
                {
                    <img src="@applyImageUrl" class="card-img-top" alt="Аплицирај онлајн">
                }
                <div class="card-body text-center">
                    <h5 class="card-title">@applyOnlineTitle</h5>
                    <a href="@applyUrl" class="btn btn-primary w-100">@applyOnlineButtonText</a>
                </div>
            </div>
        </div>

        <!-- Currency Widget -->
        <div class="col-md-4 mb-3">
            <div class="card home-exchange-rate h-100">
                <div class="card-body d-flex flex-column" style="z-index:50">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="header-title mt-0 mb-0">@exchangeRateTitle</h4>
                        <a href="@exchangeRateAllUrl" class="xrate-all-link">@exchangeRateAllLabel &gt;</a>
                    </div>
                    @await Html.PartialAsync("_CurrencyWidget")
                </div>
            </div>
        </div>

        <!-- Latest News -->
        <div class="col-md-4 mb-3">
            <div class="card h-100 home-news-card">
                <div class="card-body d-flex flex-column">
                    <div class="float-right">
                        <a href="@allNewsUrl">@latestNewsAllLabel &gt;</a>
                    </div>
                    <h4 class="header-title mt-0 mb-3">@latestNewsTitle</h4>

                    @if (latestNews.Any())
                    {
                        <div id="newsSlider" class="carousel slide flex-grow-1" data-ride="carousel" data-interval="false">
                            <div class="carousel-inner">
                                @{
                                    var newsIdx = 0;
                                }
                                @foreach (var news in latestNews)
                                {
                                    <div class="carousel-item @(newsIdx == 0 ? "active" : "")">
                                        <p class="home-news-title mt-0 mb-2">
                                            <span class="news-title-date">@(!string.IsNullOrWhiteSpace(news.PublishDate) ? news.PublishDate : "")</span>
                                            @news.Title
                                        </p>
                                        <div class="row news-article no-gutters">
                                            <div class="col-auto pr-2">
                                                <img alt="@news.Title" src="@(string.IsNullOrWhiteSpace(news.ThumbnailUrl) ? "/scraped-media/homepage/news/defaultnews.png" : news.ThumbnailUrl)">
                                            </div>
                                            <div class="col">
                                                @if (!string.IsNullOrWhiteSpace(news.Excerpt))
                                                {
                                                    @news.Excerpt
                                                }
                                                <a href="@news.Url"> @newsReadMoreLabel</a>
                                            </div>
                                        </div>
                                    </div>
                                    newsIdx++;
                                }
                            </div>
                        </div>

                        <div class="row mt-auto pt-2">
                            <div class="col-12">
                                <div class="dataTables_paginate paging_simple_numbers text-center">
                                    <ol class="pagination pagination-rounded mb-0 d-inline-flex">
                                        <li class="paginate_button page-item previous">
                                            <a href="#newsSlider" data-slide="prev" class="page-link" aria-label="Претходно">
                                                <i class="mdi mdi-chevron-left"></i>
                                            </a>
                                        </li>
                                        @for (var pi = 0; pi < latestNews.Count; pi++)
                                        {
                                            <li id="newsSlider@(pi)" data-target="#newsSlider" data-slide-to="@pi" class="paginate_button page-item @(pi == 0 ? "active" : "")">
                                                <a href="#" class="page-link">@(pi + 1)</a>
                                            </li>
                                        }
                                        <li class="paginate_button page-item next">
                                            <a href="#newsSlider" data-slide="next" class="page-link" aria-label="Наредно">
                                                <i class="mdi mdi-chevron-right"></i>
                                            </a>
                                        </li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Digital Channels 24/7 -->
