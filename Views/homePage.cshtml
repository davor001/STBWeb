}<!-- end digital-channels -->

<!-- Topsi / Golden Club promo banners -->
@if (promoBanners.Any())
{
    <div class="container-fluid web-sites pb-4">
        <div class="row pt-3">
            @{
                var promoIdx = 0;
            }
            @foreach (var promo in promoBanners)
            {
                var hasPromoUrl = !string.IsNullOrWhiteSpace(promo.Url);
                var offsetClass = promoIdx > 0 ? " offset-xl-2" : "";

                <div class="col-sm-6 col-xl-5@(offsetClass) mb-3">
                    <div class="card bg-transparent shadow-none">
                        <div class="card-body bg-transparent">
                            @if (hasPromoUrl)
                            {
                                <a href="@promo.Url">
                                    <h4 class="header-title mt-0 mb-2">@promo.Name</h4>
                                    @if (!string.IsNullOrWhiteSpace(promo.ImageUrl))
                                    {
                                        <div class="text-center">
                                            <img class="img-fluid" src="@promo.ImageUrl" alt="@promo.Name">
                                        </div>
                                    }
                                </a>
                            }
                            else
                            {
                                <h4 class="header-title mt-0 mb-2">@promo.Name</h4>
                                @if (!string.IsNullOrWhiteSpace(promo.ImageUrl))
                                {
                                    <div class="text-center">
                                        <img class="img-fluid" src="@promo.ImageUrl" alt="@promo.Name">
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
                promoIdx++;
            }
        </div>
    </div>
}
