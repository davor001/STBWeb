@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Cms.Core.Models
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListItem>
@{
    var content = Model.Content;
    var desktopImg = content.Value<MediaWithCrops>("desktopImage");
    var mobileImg  = content.Value<MediaWithCrops>("mobileImage");
    var heading    = content.Value<string>("slideHeading");
    var subheading = content.Value<string>("slideSubheading");
    var ctaText    = content.Value<string>("slideCtaText");
    var ctaUrl     = content.Value<IEnumerable<Link>>("slideCtaUrl")?.FirstOrDefault()?.Url;

    var desktopUrl = desktopImg?.MediaUrl() ?? string.Empty;
    var mobileUrl  = mobileImg?.MediaUrl()  ?? string.Empty;
    var imageUrl   = !string.IsNullOrWhiteSpace(desktopUrl) ? desktopUrl : mobileUrl;
}
<div class="carousel-item">
    @if (!string.IsNullOrWhiteSpace(imageUrl))
    {
        <picture>
            @if (!string.IsNullOrWhiteSpace(mobileUrl))
            {
                <source media="(max-width: 767.98px)" srcset="@mobileUrl">
            }
            <img src="@imageUrl" class="d-block w-100" alt="@(string.IsNullOrWhiteSpace(heading) ? string.Empty : heading)">
        </picture>
    }
    @if (!string.IsNullOrEmpty(heading))
    {
        <div class="carousel-caption carousel-caption-left2">
            <h3>@heading</h3>
            <hr/>
            @if (!string.IsNullOrEmpty(subheading))
            {
                <h4>@subheading</h4>
            }
            @if (!string.IsNullOrEmpty(ctaText) && !string.IsNullOrEmpty(ctaUrl))
            {
                <a href="@ctaUrl" class="btn btn-primary">@ctaText</a>
            }
        </div>
    }
</div>
