@using Umbraco.Cms.Core.Models.PublishedContent
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject STBWeb.Services.HomepageFallbackService HomepageFallbackService
@{
    // 1. Try Umbraco content tree (populated once Phase 1E seeding is done)
    var newsRoot = Umbraco.ContentAtRoot()
        .SelectMany(r => r.DescendantsOrSelf())
        .FirstOrDefault(c => c.ContentType.Alias == "newsListingPage");

    var tickerItems = newsRoot?.Children()
        .Where(c => c.ContentType.Alias == "newsDetailPage")
        .OrderByDescending(c => c.Value<DateTime>("publishDate"))
        .Take(10)
        .Select(c => (Title: c.Name, Url: c.Url() ?? string.Empty))
        .ToList()
        ?? new List<(string Title, string Url)>();

    // 2. Fall back to scraped-data/homepage.json when Umbraco has no news yet
    if (!tickerItems.Any())
    {
        tickerItems = HomepageFallbackService.GetData().LatestNews
            .Where(n => !string.IsNullOrWhiteSpace(n.Title))
            .Select(n => (Title: n.Title, Url: n.Url))
            .ToList();
    }
}
@if (tickerItems.Any())
{
    <div class="container-fluid d-print-none">
        <div class="row">
            <div class="col-12">
                <div class="js-conveyor-example">
                    <ul class="conveyor-content">
                        @for (var i = 0; i < tickerItems.Count; i++)
                        {
                            <li><a class="text-dark" href="@tickerItems[i].Url">@tickerItems[i].Title</a></li>
                            if (i < tickerItems.Count - 1)
                            {
                                <li>|</li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
}
