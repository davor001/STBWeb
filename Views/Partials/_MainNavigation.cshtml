    cyrillicNames["Depozit Orocen Na 1 2 3 6 12 24 36 Meseci"] = "Депозит орочен на 1, 2, 3, 6, 12, 24, 36 месеци";
    cyrillicNames["Premium"]          = "Премиум";
    cyrillicNames["Moj Plan"]         = "Мој план";
    cyrillicNames["Evrobonus"]        = "ЕвроБонус";

    // ── Loans ─────────────────────────────────────────────────────────────────
