    cyrillicNames["Brzi Plakjanja Topsi Pay"]      = "Брзи плаќања - Topsi Pay";
    cyrillicNames["ATM Plakjanja"]                 = "ATM плаќања";
    cyrillicNames["Korisni Video Upatstva"]        = "Корисни видео упатства";

    // ── Insurance ─────────────────────────────────────────────────────────────
