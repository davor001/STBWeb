@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    var home = Model.Root();

    // Primary nav: the 8 Население section items.
    // New tree (after DB reset): these are direct children of Home.
    // Old/existing tree: they live one level deeper under a "Naselenie" wrapper node.
    // The fallback below handles both so the nav works without requiring a DB reset.
    var primaryNavNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "Depoziti", "Krediti", "Karticki", "Smetki",
        "Digitalno Bankarstvo", "Osiguruvanje", "Platezni Uslugi", "Ostanato"
    };

    var topLevelNavItems = home.Children
        .Where(x => x.IsVisible() && primaryNavNames.Contains(x.Name))
        .ToList();

    // Fallback: existing DB still has old structure (Depoziti etc. under Naselenie).
    // Show all visible children of Naselenie so the nav is never empty.
    if (!topLevelNavItems.Any())
    {
        var naselenie = home.Children
            .FirstOrDefault(x => x.ContentType.Alias == "sectionRoot" &&
                                 x.Name.Equals("Naselenie", StringComparison.OrdinalIgnoreCase));
        if (naselenie != null)
            topLevelNavItems = naselenie.Children.Where(x => x.IsVisible()).ToList();
    }

    // Map romanized Umbraco node names to Cyrillic display names.
    // Keys are the MK culture names set in ContentSeeder.cs (OrdinalIgnoreCase).
    var cyrillicNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    // ── Primary nav top-level ─────────────────────────────────────────────────
    cyrillicNames["Depoziti"]             = "Депозити";
    cyrillicNames["Krediti"]              = "Кредити";
    cyrillicNames["Karticki"]             = "Картички";
    cyrillicNames["Smetki"]               = "Сметки";
    cyrillicNames["Digitalno Bankarstvo"] = "Дигитално банкарство";
    cyrillicNames["Osiguruvanje"]         = "Осигурување";
    cyrillicNames["Platezni Uslugi"]      = "Платежни услуги";
    cyrillicNames["Ostanato"]             = "Останато";

    // ── Deposits ──────────────────────────────────────────────────────────────
    cyrillicNames["Za Depozitite"]    = "За депозитите";
