    // ── Payment Services ──────────────────────────────────────────────────────
    cyrillicNames["Platezni Uslugi Vo Zemjata"]  = "Платежни услуги во земјата";
    cyrillicNames["Platezni Uslugi So Stranstvo"] = "Платежни услуги со странство";

    // ── Останато ──────────────────────────────────────────────────────────────
    cyrillicNames["Topsi Za Mladi"]                      = "ТОПСИ за млади";
    cyrillicNames["Traen Nalog"]                         = "Траен налог";
    cyrillicNames["Sefovi"]                              = "Сефови";
    cyrillicNames["Tarifi Naselenie"]                    = "Тарифи Население";
    cyrillicNames["Aplikacija Za Azuriranje Za Naselenie"] = "Апликација за ажурирање за население";
    cyrillicNames["Standardna Tabela So Podatoci"]       = "Стандардна табела со податоци по одделни кредити и депозити";
    cyrillicNames["Katce Za Korisnici"]                  = "Катче за корисници";
    cyrillicNames["Zashtita Na Licni Podatoci"]          = "Заштита на лични податоци";
    cyrillicNames["Portal Za Otvoreno Bankarstvo"]       = "Портал за отворено банкарство";

    // ── Secondary sections (not in primary nav, kept for completeness) ────────
    cyrillicNames["PRAVNI LICA"]       = "ПРАВНИ ЛИЦА";
    cyrillicNames["FINANSISKI PAZARI"] = "ФИНАНСИСКИ ПАЗАРИ";
    cyrillicNames["ZA BANKATA"]        = "ЗА БАНКАТА";
    cyrillicNames["MARKETING I OOP"]   = "МАРКЕТИНГ И ООП";
    cyrillicNames["SB LOKACII"]        = "СБ ЛОКАЦИИ";
    cyrillicNames["Kreditni Proizvodi"]      = "Кредитни производи";
    cyrillicNames["Dokumentarno Rabotenje"]  = "Документарно работење";
    cyrillicNames["E Commerce"]              = "Е-трговија";
    cyrillicNames["Kursna Lista"]            = "Курсна листа";
    cyrillicNames["Devizen Pazar"]           = "Девизен пазар";
    cyrillicNames["Brokerski Uslugi"]        = "Брокерски услуги";
