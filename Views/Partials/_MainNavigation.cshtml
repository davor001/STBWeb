    cyrillicNames["Kreditno Zivotno Osiguruvanje"]     = "Кредитно животно осигурување";
    cyrillicNames["Riziko Zivotno Osiguruvanje"]       = "Ризико животно осигурување";
    cyrillicNames["Penzisko Osiguruvanje"]             = "Пензиско осигурување";
