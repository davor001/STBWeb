@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

<!-- Search Overlay Panel -->
<div class="search-overlay" id="searchPanel" style="display: none;">
    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-4" id="closeSearch" aria-label="Close"></button>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <!-- Directing to the Surface Controller using regular GET to matching route -->
                <form action="/prebaruvanje" method="get" class="search-form-massive">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-transparent border-light text-white border-end-0 pe-0">
                            <i class="mdi mdi-magnify fs-3"></i>
                        </span>
                        <input type="text" name="q" class="form-control bg-transparent border-light border-start-0 text-white placeholder-white" placeholder="Што барате денеска?" autofocus>
                        <button class="btn btn-outline-light px-4" type="submit">Барај</button>
                    </div>
                    <div class="mt-4 text-center">
                        <p class="text-white-50 small mb-2">Најчесто пребарувани:</p>
                        <div class="d-flex flex-wrap justify-content-center gap-2">
                            <a href="/prebaruvanje?q=Кредити" class="badge rounded-pill bg-white text-dark text-decoration-none px-3 py-2 fw-normal transition-hover">Кредити</a>
                            <a href="/prebaruvanje?q=Курсна листа" class="badge rounded-pill bg-white text-dark text-decoration-none px-3 py-2 fw-normal transition-hover">Курсна листа</a>
                            <a href="/prebaruvanje?q=Филијали" class="badge rounded-pill bg-white text-dark text-decoration-none px-3 py-2 fw-normal transition-hover">Филијали</a>
                            <a href="/prebaruvanje?q=I-bank" class="badge rounded-pill bg-white text-dark text-decoration-none px-3 py-2 fw-normal transition-hover">I-bank</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<div class="rightbar-overlay"></div>
