@using Umbraco.Cms.Core.Models.PublishedContent
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "_Layout.cshtml";
    var heroBannerImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroBannerImage");
    var heroBannerHeading = Model.Value<string>("heroBannerHeading") ?? "Калкулатори";
}

@if (heroBannerImage != null)
{
    <div class="row mb-0">
        <div class="col position-relative">
            <img src="@heroBannerImage.MediaUrl()" class="w-100" alt="@heroBannerHeading" style="max-height:250px;object-fit:cover;">
            <div class="carousel-caption carousel-caption-left2">
                <h3>@heroBannerHeading</h3>
            </div>
        </div>
    </div>
}

<div class="container-fluid py-3">
    @await Html.PartialAsync("_Breadcrumb")

    <div class="row">
        <div class="col-md-8 col-xl-9">
            <h3>Калкулатори</h3>

            <!-- Calculator selector -->
            <div class="mb-4">
                <label for="SelectCalculator">Одберете производ:</label>
                <select id="SelectCalculator" class="form-control">
                    <option value="">-- Одберете --</option>
                    <option value="1">Потрошувачки кредит до 1.500.000 МКД</option>
                    <option value="2">Потрошувачки кредит до 80.000 ЕУР</option>
                    <option value="3">Потрошувачки кредит преку трговска мрежа</option>
                    <option value="4">Станбен кредит</option>
                    <option value="5">Автомобилски кредит</option>
                    <option value="6">Орочен депозит – Премиум</option>
                    <option value="7">Орочен депозит – ЕвроБонус</option>
                    <option value="8">Микро бизнис кредит (правни лица)</option>
                    <option value="9">Орочен депозит 12/13</option>
                    <option value="10">Орочен депозит 18/20</option>
                </select>
            </div>

            <!-- Calculator form area (dynamically loaded) -->
            @await Html.PartialAsync("Partials/_CalculatorsForms")
        </div>

        @await Html.PartialAsync("_Sidebar")
    </div>
</div>

