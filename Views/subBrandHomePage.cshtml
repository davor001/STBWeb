@using Umbraco.Cms.Core.Models.PublishedContent
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    var subbrandKey = Model.Value<string>("subbrandKey") ?? "topsi";
    Layout = subbrandKey == "goldenclub" ? "_GoldenClubLayout.cshtml" : "_TopsiLayout.cshtml";

    var heroSlides = Model.Value<Umbraco.Cms.Core.Models.Blocks.BlockListModel>("heroSlides");
    var bodyContent = Model.Value<Umbraco.Cms.Core.Strings.IHtmlEncodedString>("bodyContent");
    var logo = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("logo");
}

<!-- Sub-brand Hero Carousel -->
@if (heroSlides != null && heroSlides.Any())
{
    <div id="subBrandSlider" class="carousel slide" data-ride="carousel">
        <ol class="carousel-indicators">
            @{ int idx = 0; }
            @foreach (var _block in heroSlides)
            {
                <li data-target="#subBrandSlider" data-slide-to="@idx" class="@(idx == 0 ? "active" : "")"></li>
                idx++;
            }
        </ol>
        <div class="carousel-inner">
            @{ idx = 0; }
            @foreach (var slide in heroSlides)
            {
                var content = slide.Content;
                var desktopImg = content.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("desktopImage");
                var heading = content.Value<string>("slideHeading");
                var ctaText = content.Value<string>("slideCtaText");
                var ctaLinks = content.Value<IEnumerable<Umbraco.Cms.Core.Models.Link>>("slideCtaUrl");
                var ctaUrl = ctaLinks?.FirstOrDefault()?.Url;
                <div class="carousel-item @(idx == 0 ? "active" : "")">
                    @if (desktopImg != null)
                    {
                        <img src="@desktopImg.MediaUrl()" class="d-block w-100" alt="@heading">
                    }
                    @if (!string.IsNullOrEmpty(heading))
                    {
                        <div class="carousel-caption carousel-caption-left2">
                            <h3>@heading</h3>
                            @if (!string.IsNullOrEmpty(ctaText) && !string.IsNullOrEmpty(ctaUrl))
                            {
                                <a href="@ctaUrl" class="btn btn-primary">@ctaText</a>
                            }
                        </div>
                    }
                </div>
                idx++;
            }
        </div>
        <a class="carousel-control-prev" href="#subBrandSlider" role="button" data-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </a>
        <a class="carousel-control-next" href="#subBrandSlider" role="button" data-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </a>
    </div>
}

<!-- Body Content -->
@if (!bodyContent == null || string.IsNullOrWhiteSpace(bodyContent.ToString()))
{
    <div class="container-fluid py-4">
        @bodyContent
    </div>
}

<!-- Child Pages -->
@{
    var childPages = Model.Children().ToList();
}
@if (childPages.Any())
{
    <div class="container-fluid py-3">
        <div class="row">
            @foreach (var child in childPages)
            {
                <div class="col-md-4 mb-3">
                    <a href="@child.Url()" class="card d-block text-decoration-none">
                        <div class="card-body">
                            <h5 class="card-title">@child.Name</h5>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
}